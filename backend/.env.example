APP_NAME=PAM
APP_ENV=development

# PostgreSQL (default)
DATABASE_URL=postgresql+psycopg://pam:pam@localhost:5432/pam
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# SQLite fallback (for local/tests):
# DATABASE_URL=sqlite+aiosqlite:///./pam.db

CORS_ORIGINS=["http://localhost:4200"]
